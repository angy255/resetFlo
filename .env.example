# Supabase POOLED connection (port 6543, via PgBouncer) -- used at runtime
# Format: postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
DATABASE_URL=

# Supabase DIRECT connection (port 5432) -- used ONLY for prisma migrate
# Format: postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres?sslmode=require
DIRECT_URL=

# Required in production -- generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Set to your app URL (http://localhost:3000 for dev, https://your-app.vercel.app for prod)
NEXTAUTH_URL=

# Get from https://aistudio.google.com/app/apikey (free, no credit card)
GEMINI_API_KEY=
