generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  avatarColor   String?
  age           Int?
  gender        String?
  weight        Float?
  height        Float?
  trainingLevel String?
  trainingGoal  String?
  injuryNotes   String?
  createdAt     DateTime  @default(now())
  entries       Entry[]
  insights      Insight[]
}

model Entry {
  id                String      @id @default(cuid())
  userId            String
  date              DateTime    @db.Date
  workoutType       WorkoutType
  workoutDuration   Int
  perceivedExertion Int
  sorenessLevel     Int
  sleepDuration     Float
  sleepQuality      Int
  energyLevel       Int
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model Insight {
  id            String   @id @default(cuid())
  userId        String
  weekStartDate DateTime @db.Date
  content       String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum WorkoutType {
  STRENGTH
  CARDIO
  MOBILITY
  REST
  OTHER
}
